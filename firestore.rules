rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /roles/{docId} { allow read, write: if isSignedIn(); }
    match /inventory/{docId} { allow read, write: if isSignedIn(); }
    match /customers/{docId} { allow read, write: if isSignedIn(); }
    match /tasks/{docId} { allow read, write: if isSignedIn(); }
    match /qualityChecks/{docId} { allow read, write: if isSignedIn(); }
    match /labors/{docId} { allow read, write: if isSignedIn(); }
    match /laborAttendances/{docId} { allow read, write: if isSignedIn(); }
    match /activityLogs/{docId} { allow read, write: if isSignedIn(); }
    match /inventoryUsages/{docId} { allow read, write: if isSignedIn(); }
    match /labRoutineChecks/{docId} { allow read, write: if isSignedIn(); }
    match /labSpecialMeasures/{docId} { allow read, write: if isSignedIn(); }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Check if the user document exists and has admin role
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleId == 'role-admin';
    }

    // User Model
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'roleId']) &&
             data.keys().size() >= 4 &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.roleId is string;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(userId) && existing().uid == incoming().uid && (
        isAdmin() || 
        (userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['name']))
      );
      allow delete: if isAdmin();
    }

    // Order Model
    function isValidOrder(data) {
      return data.keys().hasAll(['orderNumber', 'customerName', 'items', 'status', 'dueDate', 'totalValue', 'originalOwnerId']) &&
             data.keys().size() == 7 &&
             data.orderNumber is string && data.orderNumber.size() > 0 && data.orderNumber.size() <= 50 &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 100 &&
             data.items is number && data.items >= 0 &&
             data.status is string && data.status.size() > 0 && data.status.size() <= 50 &&
             data.dueDate is string && data.dueDate.size() <= 50 &&
             data.totalValue is number && data.totalValue >= 0 &&
             data.originalOwnerId is string && data.originalOwnerId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update: if isSignedIn() && isValidId(orderId) && 
        incoming().originalOwnerId == existing().originalOwnerId && 
        (
           isAdmin() ||
           // System assumes any user can update an order's status as part of the flow
           (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
           (existing().originalOwnerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAny(['status', 'items', 'totalValue', 'customerName', 'dueDate', 'orderNumber']))
        );
      allow delete: if isAdmin() || existing().originalOwnerId == request.auth.uid;
    }
  }
}
